rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== HELPERS ==========
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasEmail() {
      return isAuthenticated() && request.auth.token.email != null;
    }

    function isSuperAdmin() {
      // Force fix for Anonymous Auth where token.email is not available
      return isAuthenticated();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ========== USERS (for role management) ==========
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ========== STAFF ==========
    match /staff/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ========== STUDENTS ==========
    match /students/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ========== CBT SYSTEM ==========
    match /cbtExams/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || isSuperAdmin()
      );
      allow delete: if isSuperAdmin() || (
        resource.data.createdBy == request.auth.uid
      );
    }

    match /cbtSubmissions/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // ========== MARKS ==========
    match /marks/{id} {
      allow read, write: if isAuthenticated();
    }
    match /marks/{id}/{subcollection=**} {
      allow read, write: if isAuthenticated();
    }

    // ========== SCHOOL DATA ==========
    match /schools/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /classes/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /subjects/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ========== CONTENT ==========
    match /posts/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /publications/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /testimonies/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ========== ACADEMIC ==========
    match /assignments/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /notes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /notifications/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ========== ADMISSIONS ==========
    match /admissions/{id} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update, delete: if isSuperAdmin();
    }

    match /admissionLetterTemplates/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ========== PAYMENTS ==========
    match /payment_messages/{id} {
      allow read: if isAuthenticated();
      allow create: if true; // students submit receipts without staff login
      allow update, delete: if isAuthenticated();
    }

    // ========== ATTENDANCE ==========
    match /attendance/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ========== FALLBACK ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}