rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated via Firebase Auth?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Is the user the specific super admin?
    // Requires Email/Password or Google Auth for email field
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'globixtechinc@gmail.com' ||
        request.auth.token.email == 'admin@birxysms.edu'
      );
    }

    // Helper: Is the user a staff member?
    function isStaff() {
      return isAuthenticated(); // For now, allow any auth'd user to be staff if we use anonymous auth as bridge
    }

    // 1. Staff Records: Only Super Admin can manage staff list
    match /staff/{id} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // 2. Student Records: Public read for login, auth'd write
    match /students/{id} {
      allow read: if true; 
      allow write: if isAuthenticated();
    }

    // 3. CBT System
    match /cbtExams/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /cbtSubmissions/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // 4. Academic Marks
    match /marks/{id} {
      allow read, write: if isAuthenticated();
    }
    match /marks/{id}/{subcollection=**} {
      allow read, write: if isAuthenticated();
    }

    // 5. General Collections
    match /subjects/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /publications/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /testimonies/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /settings/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /posts/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /assignments/{id} { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }
    match /notes/{id} { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }
    match /notifications/{id} { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }
    match /schools/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /classes/{id} { allow read: if true; allow write: if isAuthenticated(); }

    // Default: Authenticated users can read/write other things
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
